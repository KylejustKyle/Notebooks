    "    \"    <address>\\n\" +\n",
    "    \"        <forename>Camellya</forename>\\n\" +\n",
    "    \"        <surname/>\\n\" +\n",
    "    \"        <email>crazy@blackshores.com</email>\\n\" +\n",
    "    \"        <powerlevel>340</powerlevel>\\n\" +\n",
    "    \"    </address>\\n\" +\n",
    "    \"    <address>\\n\" +\n",
    "    \"        <forename>Cantarella</forename>\\n\" +\n",
    "    \"        <surname>Fisalia</surname>\\n\" +\n",
    "    \"        <email></email>\\n\" +\n",
    "    \"        <powerlevel>875</powerlevel>\\n\" +\n",
    "    \"    </address>\\n\" +\n",
    "    \"    <address>\\n\" +\n",
    "    \"        <forename>Ciaccona</forename>\\n\" +\n",
    "    \"        <surname></surname>\\n\" +\n",
    "    \"        <email>kawaii-bard@wuwa.com</email>\\n\" +\n",
    "    \"        <powerlevel>120</powerlevel>\\n\" +\n",
    "    \"    </address>\\n\" +\n",
    "    \"    <address>\\n\" +\n",
    "    \"        <forename>Carlotta</forename>\\n\" +\n",
    "    \"        <surname>Montelli</surname>\\n\" +\n",
    "    \"        <email>opal@rinascita.com</email>\\n\" +\n",
    "    \"        <powerlevel>610</powerlevel>\\n\" +\n",
    "    \"    </address>\\n\" +\n",
    "    \"</addressbook>\";\n",
    "System.out.println(\"addressBookXml ready (\" + addressBookXml.length() + \" characters)\");"
